# Sales Pulse Daily - Email Configuration
# Copy this file to .env and fill in your SMTP credentials

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@astutegroup.com
SMTP_PASS=your-app-password

# Email Settings
SMTP_FROM="Sales Pulse <noreply@astutegroup.com>"

# Recipients (comma-separated) - TESTING PHASE
RECIPIENTS=josh.pucci@astutegroup.com,melissa.bojar@astutegroup.com

