# iDempiere REST API Configuration
# Copy these variables to ~/workspace/.env and fill in your credentials.
# See shared/api-writeback.md for full documentation.

# Base URL for the iDempiere REST API (no trailing slash)
IDEMPIERE_BASE_URL=http://172.31.28.106:8080/api/v1

# Login credentials (must have a role with Role Type = WebService or blank)
IDEMPIERE_USERNAME=
IDEMPIERE_PASSWORD=

# Auth parameters (sent in one-step login POST /auth/tokens)
IDEMPIERE_CLIENT_ID=1000000
IDEMPIERE_ROLE_ID=1000056
IDEMPIERE_ORG_ID=1000000
