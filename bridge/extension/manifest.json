{
  "manifest_version": 3,
  "name": "Claude Bridge",
  "version": "2.0.0",
  "description": "Bridge between Chrome and Claude Code terminal — with debugger-based real input simulation",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "debugger"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Claude Bridge",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
